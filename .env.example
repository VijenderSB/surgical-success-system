# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Absolute path to the built client. Defaults to ./dist relative to server.
# PUBLIC_DIR=/var/www/transess/dist

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string (required for /api/leads)
DATABASE_URL=postgres://transess:CHANGE_ME@127.0.0.1:5432/transess
# Set to "true" if your Postgres requires SSL (managed providers usually do)
PGSSL=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Empty = permissive.
CORS_ORIGINS=https://transess.com,https://www.transess.com
